{
  "name": "hyper-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing ScoutOS-style data/cache/blob/queue/search ports backed by persistent PGLite",
  "type": "module",
  "bin": {
    "hyper-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts src/http.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/http.js",
    "start:stdio": "node dist/index.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
